<section class="grid two">
  <div class="panel hero-panel">
    <p class="status-pill">Hoje</p>
    <h1>Continue pelo proximo movimento certo.</h1>

    <% if @current_chapter %>
      <p class="muted">
        Chapter atual: <strong><%= @current_chapter.title %></strong>
      </p>
      <div class="button-row">
        <%= link_to "Abrir chapter", chapter_path(@current_chapter.slug), class: "button" %>
        <%= link_to "Ver drills", drills_path, class: "button secondary" %>
        <%= link_to "Sessao adaptativa", adaptive_session_path, class: "button secondary" %>
        <%= link_to "Rodar simulador", simulations_path, class: "button ghost" %>
      </div>
    <% else %>
      <div class="empty-state">
        Nenhum conteudo importado ainda. Rode <code>bin/rails study:sync_content</code>.
      </div>
    <% end %>
  </div>

  <aside class="panel">
    <h2 class="section-title">Post-its</h2>
    <div class="postits">
      <% if @reminders.any? %>
        <% @reminders.each do |reminder| %>
          <article class="postit">
            <p><%= reminder.message %></p>
            <div class="button-row">
              <%= button_to "Soneca", snooze_reminder_path(reminder), method: :post, class: "button ghost small-form" %>
              <%= button_to "Fechar", dismiss_reminder_path(reminder), method: :post, class: "button ghost small-form" %>
            </div>
          </article>
        <% end %>
      <% else %>
        <p class="muted">Sem lembretes ativos. Eles aparecem quando voce marcar algo como hesitante ou errado.</p>
      <% end %>
    </div>
  </aside>
</section>

<section class="grid three">
  <article class="panel">
    <h2>Chapters</h2>
    <p class="muted"><%= @chapters.size %> importados</p>
  </article>

  <article class="panel">
    <h2>Reviews vencidos</h2>
    <p class="muted"><%= @due_reviews.size %> na fila</p>
  </article>

  <article class="panel">
    <h2>Status</h2>
    <p class="muted">
      Mastered: <%= @progress_counts.fetch("mastered", 0) %>
      · Reading: <%= @progress_counts.fetch("reading", 0) %>
    </p>
  </article>
</section>

<section class="grid three">
  <article class="panel">
    <h2>Adaptativo</h2>
    <p class="muted">
      <%= @misconception_count %> misconceptions
      · <%= @low_confidence_count %> baixa/media confianca
    </p>
    <div class="button-row">
      <%= link_to "Montar sessao", adaptive_session_path, class: "button secondary" %>
      <%= link_to "Ver ledger", misconceptions_path, class: "button ghost" %>
    </div>
  </article>

  <article class="panel">
    <h2>Simuladores</h2>
    <p class="muted"><%= @simulation_attempt_count %> tentativas registradas</p>
    <%= link_to "Abrir simuladores", simulations_path, class: "button secondary" %>
  </article>

  <article class="panel">
    <h2>LLM Foundations</h2>
    <% if @llm_foundations %>
      <p class="muted">
        <%= @llm_foundations.metadata["chapter_count"] %> chapters
        · <%= @llm_foundations_record_count %> learning records
      </p>
      <% if @llm_foundations.study_mission %>
        <p><strong>Mission:</strong> <%= truncate(@llm_foundations.study_mission.why_now, length: 96) %></p>
      <% else %>
        <p class="muted">Sem mission definida ainda.</p>
      <% end %>
      <%= link_to "Abrir trilha", side_track_path(@llm_foundations.slug), class: "button secondary" %>
    <% else %>
      <p class="muted">Sincronize o conteudo para importar a trilha paralela de IA.</p>
      <%= link_to "Ver trilhas", side_tracks_path, class: "button secondary" %>
    <% end %>
  </article>

  <article class="panel">
    <h2>Fundamentos e componentes</h2>
    <p class="muted">
      <%= @library_counts.fetch("foundation", 0) %> fundamentos
      · <%= @library_counts.fetch("component_card", 0) %> cards
    </p>
    <%= link_to "Consultar", library_path(kind: "foundation"), class: "button secondary" %>
  </article>

  <article class="panel">
    <h2>IA e casos reais</h2>
    <p class="muted">
      <%= @library_counts.fetch("ai_system", 0) %> topicos IA
      · <%= @library_counts.fetch("real_world_case", 0) %> casos
    </p>
    <%= link_to "Ver casos", library_path(kind: "real_world_case"), class: "button secondary" %>
  </article>

  <article class="panel">
    <h2>Ops e practice</h2>
    <p class="muted">
      <%= @library_counts.fetch("operational_playbook", 0) %> playbooks
      · <%= @library_counts.fetch("engineering_practice", 0) %> cards
    </p>
    <%= link_to "Abrir playbooks", library_path(kind: "operational_playbook"), class: "button secondary" %>
  </article>

  <article class="panel">
    <h2>Labs adicionais</h2>
    <p class="muted">
      <%= @library_counts.fetch("backend_lab", 0) %> backend
      · <%= @library_counts.fetch("engineering_case_lab", 0) %> case study
    </p>
    <%= link_to "Abrir labs", library_path(kind: "backend_lab"), class: "button secondary" %>
  </article>
</section>

<section class="panel">
  <h2 class="section-title">Fila de revisao</h2>
  <% if @due_reviews.any? %>
    <div class="chapter-list">
      <% @due_reviews.each do |schedule| %>
        <div class="chapter-row">
          <span class="chapter-number"><%= schedule.interval_days %>d</span>
          <div>
            <strong><%= schedule.study_document.title %></strong>
            <p class="muted"><%= schedule.checkpoint&.prompt || "Review do documento" %></p>
          </div>
          <%= link_to "Abrir", chapter_path(schedule.study_document.slug), class: "button secondary" if schedule.study_document.chapter? %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="muted">Nenhuma revisao vencida agora.</p>
  <% end %>
</section>
