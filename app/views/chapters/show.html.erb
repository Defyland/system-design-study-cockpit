<section class="reader">
  <article class="reader-content">
    <div class="panel hero-panel">
      <p class="status-pill">Chapter <%= @chapter.position.to_s.rjust(2, "0") %></p>
      <h1><%= @chapter.title %></h1>
      <p class="muted"><%= @chapter.phase %></p>
      <div class="button-row">
        <%= button_to "Marcar como lido",
          study_progress_path(@progress),
          method: :patch,
          params: { study_document_id: @chapter.id, study_progress: { current_block_position: @blocks.size, status: "read" } },
          class: "button" %>
        <%= link_to "Voltar aos chapters", chapters_path, class: "button secondary" %>
      </div>
    </div>

    <% @blocks.each do |block| %>
      <section id="block-<%= block.position %>" class="markdown-block">
        <%= render_markdown(block.content_markdown) %>
      </section>

      <% if (checkpoint = @checkpoint_slots[block.position]) %>
        <%= render "checkpoint", checkpoint: checkpoint %>
      <% end %>
    <% end %>
  </article>

  <aside class="panel">
    <h2>Progresso</h2>
    <p class="muted"><%= @progress.status.humanize %></p>
    <p>Ultimo bloco: <%= @progress.current_block_position %>/<%= @blocks.size %></p>
    <h3>Checkpoints</h3>
    <p><%= @chapter.checkpoints.size %> perguntas extraidas</p>

    <% if @study_context.available? %>
      <div class="context-divider"></div>
      <h2>Study Context</h2>
      <p class="status-pill">Ordem <%= @study_context.study_order %></p>
      <dl class="study-context-list">
        <dt>Fase</dt>
        <dd><%= @study_context.phase_title %></dd>

        <dt>Caso principal</dt>
        <dd><%= study_context_link(@study_context.primary_case) %></dd>

        <% if @study_context.complementary_cases.any? %>
          <dt>Casos complementares</dt>
          <dd><%= study_context_links(@study_context.complementary_cases) %></dd>
        <% end %>

        <dt>Area principal</dt>
        <dd><%= study_context_link(@study_context.primary_area) %></dd>

        <% if @study_context.secondary_areas.any? %>
          <dt>Areas secundarias</dt>
          <dd><%= study_context_links(@study_context.secondary_areas) %></dd>
        <% end %>

        <dt>Lab</dt>
        <dd><%= study_context_link(@study_context.lab) %></dd>

        <dt>Review card</dt>
        <dd><%= study_context_link(@study_context.review_card) %></dd>

        <dt>Contraste</dt>
        <dd><%= study_context_link(@study_context.suggested_contrast) %></dd>

        <% if @study_context.simulations.any? %>
          <dt>Simuladores</dt>
          <dd><%= study_context_links(@study_context.simulations) %></dd>
        <% end %>
      </dl>

      <% if @study_context.mastery_objectives.any? || @study_context.interview_objectives.any? %>
        <h3>Objetivo</h3>
        <% if @study_context.mastery_objectives.any? %>
          <p class="muted"><strong>Mastery:</strong> <%= @study_context.mastery_objectives.to_sentence %></p>
        <% end %>
        <% if @study_context.interview_objectives.any? %>
          <p class="muted"><strong>Entrevista:</strong> <%= @study_context.interview_objectives.to_sentence %></p>
        <% end %>
      <% end %>
    <% end %>
  </aside>
</section>
