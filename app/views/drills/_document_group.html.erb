<article class="panel">
  <h2><%= title %></h2>
  <div class="chapter-list">
    <% documents.each do |document| %>
      <div class="drill-card">
        <% if ContentKind.library_keys.include?(document.kind) %>
          <strong><%= link_to document.title, library_document_path(kind: document.kind, slug: document.slug) %></strong>
        <% else %>
          <strong><%= document.title %></strong>
        <% end %>
        <p class="muted"><%= pluralize(document.checkpoints.size, "checkpoint") %></p>
      </div>
    <% end %>
  </div>
</article>
