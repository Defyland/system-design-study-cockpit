<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "System Design Study Cockpit" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="System Design Study Cockpit">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="topbar">
      <div>
        <%= link_to "Study Cockpit", root_path, class: "brand" %>
        <span class="subtitle">System Design</span>
      </div>

      <nav class="nav">
        <%= link_to "Dashboard", root_path %>
        <%= link_to "Chapters", chapters_path %>
        <%= link_to "Drills", drills_path %>
        <%= link_to "Adaptativo", adaptive_session_path %>
        <%= link_to "Misconceptions", misconceptions_path %>
        <%= link_to "Simuladores", simulations_path %>
        <%= link_to "Fundamentos", library_path(kind: "foundation") %>
        <%= link_to "Componentes", library_path(kind: "component_card") %>
        <%= link_to "IA", library_path(kind: "ai_system") %>
        <%= link_to "Casos", library_path(kind: "real_world_case") %>
      </nav>
    </header>

    <main class="page">
      <% flash.each do |type, message| %>
        <div class="flash <%= type %>"><%= message %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
